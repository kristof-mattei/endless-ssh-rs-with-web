  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id\n            , ip_address as \"ip_address: DbIpAddr\"\n            , connected_at\n            , disconnected_at\n            , time_spent as \"time_spent: DbDuration\"\n            , bytes_sent\n            , country_code\n            , country_name\n            , city\n            , latitude\n            , longitude\n        FROM\n            connections\n        WHERE\n            id > $1\n        ORDER BY\n            id\n        LIMIT $2\n        ",
