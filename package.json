    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --",
            "depcruise --config dependency-cruiser.config.mjs --include-only ^front-end/src/ --validate --"
        ],
        "*": [
            "prettier --ignore-unknown --"
        ]
    },
